{
  "name": "liferay-headless-sdk",
  "version": "1.0.6",
  "description": "A production-ready JavaScript SDK dynamically generated from Liferay Headless API Swagger/OpenAPI specifications.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    }
  },
  "bin": {
    "liferay-sdk-cli": "./src/cli.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "client.js",
    "swagger-loader.js",
    "api-generator.js",
    "http.js",
    "auth.js",
    "errors.js",
    "pagination.js",
    "utils.js",
    "cli.js",
    "README.md"
  ],
  "scripts": {
    "build": "echo 'No build step required for ES modules'",
    "dev": "node example/index.mjs"
  },
  "keywords": [
    "liferay",
    "headless",
    "api",
    "sdk",
    "openapi",
    "swagger",
    "rest",
    "client"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
