{
  "name": "liferay-headless-sdk",
  "version": "1.0.0",
  "description": "A production-ready JavaScript SDK dynamically generated from Liferay Headless API Swagger/OpenAPI specifications.",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "bin": {
    "liferay-sdk-cli": "./cli.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "client.js",
    "swagger-loader.js",
    "api-generator.js",
    "http.js",
    "auth.js",
    "errors.js",
    "pagination.js",
    "utils.js",
    "cli.js",
    "README.md"
  ],
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint .",
    "build": "echo 'No build step required for ES modules'"
  },
  "keywords": [
    "liferay",
    "headless",
    "api",
    "sdk",
    "openapi",
    "swagger",
    "rest",
    "client"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2022": true,
      "node": true
    },
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "warn",
      "prefer-const": "error",
      "no-var": "error"
    }
  }
}
